msgstr "Semantisches Matching mit OpenAI Embeddings aktivieren"

#: admin/views/settings.php
msgid "OpenAI API Key"
msgstr "OpenAI API-Schlüssel"

#: admin/views/settings.php
msgid "Auto-Apply Confidence"
msgstr "Auto-Anwenden-Konfidenz"

#: admin/views/settings.php
msgid "Matches above this score are auto-applied. Below = manual review."
msgstr "Treffer über diesem Wert werden automatisch angewendet. Darunter = manuelle Überprüfung."

#: admin/views/settings.php
msgid "Daily API Budget"
msgstr "Tägliches API-Budget"

#: admin/views/settings.php
msgid "Maximum number of API calls per day to control costs."
msgstr "Maximale Anzahl an API-Aufrufen pro Tag zur Kostenkontrolle."

